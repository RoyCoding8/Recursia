# Recursia backend local environment
# Select ONE provider via LLM_PROVIDER.

LLM_PROVIDER=stub
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
BACKEND_ENV_PRECEDENCE=dotenv_wins

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL=

# --- AWS Bedrock (SigV4) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=

BACKEND_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
